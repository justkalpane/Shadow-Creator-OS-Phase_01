{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shadow-empire.local/schemas/packets/platform_package_packet.schema.json",
  "title": "PlatformPackagePacket",
  "description": "Platform-specific packaging packet emitted by CWF-320.",
  "type": "object",
  "required": [
    "instance_id",
    "artifact_family",
    "schema_version",
    "producer_workflow",
    "dossier_ref",
    "created_at",
    "status",
    "payload"
  ],
  "properties": {
    "instance_id": {
      "type": "string",
      "pattern": "^PPP-[0-9]+$"
    },
    "artifact_family": {
      "type": "string",
      "const": "platform_package_packet"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "producer_workflow": {
      "type": "string",
      "const": "SE-N8N-CWF-320-Platform-Packager"
    },
    "dossier_ref": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9-]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["CREATED", "VALIDATED", "FAILED"]
    },
    "payload": {
      "type": "object",
      "required": ["narrative", "context", "evidence", "quality", "status"],
      "properties": {
        "narrative": {
          "type": "object",
          "required": ["content", "platform_structured_body", "delivery_ready"],
          "properties": {
            "content": {
              "type": "object"
            },
            "platform_structured_body": {
              "type": "object",
              "required": ["format", "structure", "estimated_delivery_length", "chapter_markers_required"],
              "properties": {
                "format": {
                  "type": "string"
                },
                "structure": {
                  "type": "array",
                  "items": {"type": "string"},
                  "minItems": 1
                },
                "estimated_delivery_length": {
                  "type": "string"
                },
                "chapter_markers_required": {
                  "type": "boolean"
                }
              },
              "additionalProperties": false
            },
            "delivery_ready": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        "context": {
          "type": "object",
          "required": ["sourced_from_packet_id", "target_platform", "execution_requirements", "platform_metadata", "platform_format_rules"],
          "properties": {
            "sourced_from_packet_id": {
              "type": "string"
            },
            "target_platform": {
              "type": "string",
              "enum": ["youtube", "blog", "podcast", "email"]
            },
            "execution_requirements": {
              "type": "object"
            },
            "platform_metadata": {
              "type": "object"
            },
            "platform_format_rules": {
              "type": "object"
            }
          },
          "additionalProperties": false
        },
        "evidence": {
          "type": "object",
          "required": ["lineage_references", "validation_checks"],
          "properties": {
            "lineage_references": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["type", "id"],
                "properties": {
                  "type": {"type": "string"},
                  "id": {"type": "string"}
                },
                "additionalProperties": false
              }
            },
            "validation_checks": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["check", "result"],
                "properties": {
                  "check": {"type": "string"},
                  "result": {"type": "string"}
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        "quality": {
          "type": "object",
          "required": ["platform_readiness_score", "gate_checks", "packaging_complete"],
          "properties": {
            "platform_readiness_score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "gate_checks": {
              "type": "object",
              "required": ["format_rules_applied", "metadata_complete", "structure_defined"],
              "properties": {
                "format_rules_applied": {"type": "boolean"},
                "metadata_complete": {"type": "boolean"},
                "structure_defined": {"type": "boolean"}
              },
              "additionalProperties": false
            },
            "packaging_complete": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        "status": {
          "type": "object",
          "required": ["decision_path", "next_workflow", "escalation_needed"],
          "properties": {
            "decision_path": {"type": "string"},
            "next_workflow": {"type": "string", "enum": ["CWF-330", "WF-900"]},
            "escalation_needed": {"type": "boolean"}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
