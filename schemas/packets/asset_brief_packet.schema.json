{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shadow-empire.local/schemas/packets/asset_brief_packet.schema.json",
  "title": "AssetBriefPacket",
  "description": "Output packet from CWF-330 containing all downstream asset briefs for media production (WF-400): thumbnail, B-roll, captions, and audio direction.",
  "type": "object",
  "required": ["instance_id", "artifact_family", "schema_version", "producer_workflow", "dossier_ref", "created_at", "status", "payload"],
  "properties": {
    "instance_id": {
      "type": "string",
      "description": "Unique identifier prefixed ABP-",
      "pattern": "^ABP-"
    },
    "artifact_family": {
      "type": "string",
      "const": "asset_brief_packet"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "producer_workflow": {
      "type": "string",
      "description": "Workflow that produced this packet"
    },
    "dossier_ref": {
      "type": "string",
      "description": "Parent dossier identifier"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["CREATED", "PARTIAL"]
    },
    "payload": {
      "type": "object",
      "required": ["narrative", "context", "evidence", "quality", "status", "assets"],
      "properties": {
        "narrative": {
          "type": "object",
          "required": ["source_platform", "content_title"],
          "properties": {
            "source_platform": { "type": "string" },
            "content_title": { "type": "string" },
            "asset_count": {
              "type": "object",
              "properties": {
                "thumbnail_briefs": { "type": "integer", "minimum": 0 },
                "broll_cues": { "type": "integer", "minimum": 0 },
                "caption_briefs": { "type": "integer", "minimum": 0 },
                "audio_direction_briefs": { "type": "integer", "minimum": 0 }
              }
            }
          },
          "additionalProperties": false
        },
        "context": {
          "type": "object",
          "required": ["sourced_from_packet_id", "target_platform"],
          "properties": {
            "sourced_from_packet_id": { "type": "string", "description": "platform_package_packet instance_id" },
            "target_platform": { "type": "string", "enum": ["youtube", "blog", "podcast", "email"] },
            "execution_requirements": { "type": "object" }
          },
          "additionalProperties": false
        },
        "evidence": {
          "type": "object",
          "required": ["lineage_references", "validation_checks"],
          "properties": {
            "lineage_references": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["type", "id"],
                "properties": {
                  "type": { "type": "string" },
                  "id": { "type": "string" }
                }
              }
            },
            "validation_checks": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["check", "result"],
                "properties": {
                  "check": { "type": "string" },
                  "result": { "type": "string" }
                }
              }
            }
          },
          "additionalProperties": false
        },
        "quality": {
          "type": "object",
          "required": ["asset_brief_completeness", "gate_checks", "asset_brief_ready_for_wf400"],
          "properties": {
            "asset_brief_completeness": { "type": "number", "minimum": 0, "maximum": 1 },
            "gate_checks": {
              "type": "object",
              "properties": {
                "thumbnail_brief_complete": { "type": "boolean" },
                "broll_brief_complete": { "type": "boolean" },
                "caption_brief_complete": { "type": "boolean" },
                "audio_brief_addressed": { "type": "boolean" }
              }
            },
            "asset_brief_ready_for_wf400": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "status": {
          "type": "object",
          "required": ["decision_path", "next_workflow", "escalation_needed"],
          "properties": {
            "decision_path": { "type": "string" },
            "next_workflow": { "type": "string", "const": "CWF-340" },
            "escalation_needed": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "assets": {
          "type": "object",
          "required": ["thumbnail_brief", "broll_cue_list", "caption_brief"],
          "properties": {
            "thumbnail_brief": {
              "type": "object",
              "description": "Thumbnail creative direction for the target platform",
              "properties": {
                "dimensions": { "type": "string" },
                "format": { "type": "string" },
                "style": { "type": "string" },
                "primary_text": { "type": "string" },
                "visual_direction": { "type": "string" },
                "color_palette": { "type": "string" },
                "do_not_use": {
                  "type": "array",
                  "items": { "type": "string" },
                  "minItems": 1
                }
              }
            },
            "broll_cue_list": {
              "type": "array",
              "description": "Ordered list of B-roll and visual cues per script section",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["section", "cue", "type"],
                "properties": {
                  "section": { "type": "string" },
                  "cue": { "type": "string" },
                  "type": { "type": "string" },
                  "duration": { "type": "string" },
                  "dimensions": { "type": "string" }
                }
              }
            },
            "caption_brief": {
              "type": "object",
              "description": "Caption and accessibility requirements",
              "properties": {
                "caption_type": { "type": "string" },
                "language": { "type": "string" },
                "accessibility_standard": { "type": "string" },
                "review_required": { "type": "boolean" }
              }
            },
            "audio_direction": {
              "description": "Audio production direction (null for platforms without audio)",
              "oneOf": [
                { "type": "null" },
                {
                  "type": "object",
                  "properties": {
                    "target_lufs": { "type": "number" },
                    "peak_ceiling_db": { "type": "number" },
                    "noise_floor_db": { "type": "number" },
                    "format": { "type": "string" }
                  }
                }
              ]
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
