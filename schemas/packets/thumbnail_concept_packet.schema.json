{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Thumbnail Concept Packet",
  "description": "Schema for thumbnail design concepts from CWF-410-thumbnail-generator",
  "type": "object",
  "required": [
    "instance_id",
    "artifact_family",
    "schema_version",
    "producer_workflow",
    "dossier_ref",
    "created_at",
    "status",
    "payload"
  ],
  "properties": {
    "instance_id": {
      "type": "string",
      "pattern": "^TCP-[0-9]+$",
      "description": "Unique packet instance ID (TCP-timestamp)"
    },
    "artifact_family": {
      "type": "string",
      "enum": ["thumbnail_concept_packet"],
      "description": "Packet type identifier"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Schema version (semantic versioning)"
    },
    "producer_workflow": {
      "type": "string",
      "enum": ["SE-N8N-CWF-410-Thumbnail-Generator"],
      "description": "Originating workflow identifier"
    },
    "dossier_ref": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9-]+$",
      "description": "Reference to parent dossier"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO8601 timestamp of packet creation"
    },
    "status": {
      "type": "string",
      "enum": ["CREATED", "VALIDATED", "FAILED"],
      "description": "Current packet status"
    },
    "payload": {
      "type": "object",
      "required": ["narrative", "context", "evidence", "quality", "status"],
      "description": "Five-section packet payload",
      "properties": {
        "narrative": {
          "type": "object",
          "required": [
            "source_title",
            "source_hook",
            "target_platform",
            "concept_count"
          ],
          "properties": {
            "source_title": {
              "type": "string",
              "minLength": 1,
              "maxLength": 200,
              "description": "Script title used for thumbnail design"
            },
            "source_hook": {
              "type": "string",
              "minLength": 1,
              "maxLength": 500,
              "description": "Hook statement guiding thumbnail strategy"
            },
            "target_platform": {
              "type": "string",
              "enum": ["youtube", "tiktok", "instagram"],
              "description": "Platform for thumbnail design"
            },
            "concept_count": {
              "type": "integer",
              "enum": [3],
              "description": "Number of thumbnail concepts (always 3)"
            }
          }
        },
        "context": {
          "type": "object",
          "required": [
            "sourced_from_packet_id",
            "platform_requirements"
          ],
          "properties": {
            "sourced_from_packet_id": {
              "type": "string",
              "pattern": "^CEP-[0-9]+$",
              "description": "Source context_engineering_packet ID"
            },
            "platform_requirements": {
              "type": "object",
              "required": ["youtube", "tiktok", "instagram"],
              "properties": {
                "youtube": {
                  "type": "string",
                  "enum": ["1280x720"],
                  "description": "YouTube thumbnail dimensions"
                },
                "tiktok": {
                  "type": "string",
                  "enum": ["1080x1920"],
                  "description": "TikTok thumbnail dimensions"
                },
                "instagram": {
                  "type": "string",
                  "enum": ["1200x675"],
                  "description": "Instagram thumbnail dimensions"
                }
              }
            }
          }
        },
        "evidence": {
          "type": "object",
          "required": ["concepts"],
          "properties": {
            "concepts": {
              "type": "array",
              "minItems": 3,
              "maxItems": 3,
              "items": {
                "type": "object",
                "required": [
                  "concept_id",
                  "strategy",
                  "visual_description",
                  "color_palette",
                  "typography_guidance",
                  "focal_point_description"
                ],
                "properties": {
                  "concept_id": {
                    "type": "string",
                    "enum": ["concept_1", "concept_2", "concept_3"],
                    "description": "Concept identifier"
                  },
                  "strategy": {
                    "type": "string",
                    "enum": [
                      "curiosity_gap",
                      "authority_data",
                      "shock_urgency"
                    ],
                    "description": "Thumbnail design strategy"
                  },
                  "visual_description": {
                    "type": "string",
                    "minLength": 10,
                    "maxLength": 500,
                    "description": "Visual design description"
                  },
                  "color_palette": {
                    "type": "array",
                    "minItems": 2,
                    "maxItems": 4,
                    "items": {
                      "type": "string",
                      "pattern": "^#[0-9A-Fa-f]{6}$"
                    },
                    "description": "Hex color codes for the design"
                  },
                  "typography_guidance": {
                    "type": "string",
                    "enum": [
                      "bold_sans_serif",
                      "clean_sans_serif",
                      "bold_condensed"
                    ],
                    "description": "Typography recommendation"
                  },
                  "focal_point_description": {
                    "type": "string",
                    "minLength": 5,
                    "maxLength": 200,
                    "description": "Primary visual focal point"
                  }
                }
              }
            }
          }
        },
        "quality": {
          "type": "object",
          "required": [
            "concept_distinctiveness",
            "platform_compliance",
            "contrast_ratio",
            "legibility_score",
            "designer_confidence"
          ],
          "properties": {
            "concept_distinctiveness": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Score 0-1: how different concepts are from each other"
            },
            "platform_compliance": {
              "type": "boolean",
              "description": "All concepts comply with platform dimensions"
            },
            "contrast_ratio": {
              "type": "number",
              "minimum": 1,
              "maximum": 21,
              "description": "WCAG color contrast ratio"
            },
            "legibility_score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Score 0-1: text legibility at preview size"
            },
            "designer_confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Designer confidence in concepts"
            }
          }
        },
        "status": {
          "type": "object",
          "required": [
            "concepts_generated",
            "all_pass_validation",
            "next_stage",
            "decision"
          ],
          "properties": {
            "concepts_generated": {
              "type": "integer",
              "enum": [3],
              "description": "Number of concepts generated"
            },
            "all_pass_validation": {
              "type": "boolean",
              "description": "All concepts pass validation"
            },
            "next_stage": {
              "type": "string",
              "enum": ["CWF-420"],
              "description": "Next workflow stage"
            },
            "decision": {
              "type": "string",
              "enum": ["PROCEED_TO_VISUAL_ASSET_PLANNING"],
              "description": "Routing decision"
            }
          }
        }
      }
    }
  }
}
