{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Media Production Packet",
  "description": "Schema for complete assembled media production package from CWF-440-media-package-finalizer",
  "type": "object",
  "required": [
    "instance_id",
    "artifact_family",
    "schema_version",
    "producer_workflow",
    "dossier_ref",
    "created_at",
    "status",
    "payload"
  ],
  "properties": {
    "instance_id": {
      "type": "string",
      "pattern": "^MDP-[0-9]+$",
      "description": "Unique media production packet ID"
    },
    "artifact_family": {
      "type": "string",
      "enum": ["media_production_packet"],
      "description": "Packet type identifier"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "producer_workflow": {
      "type": "string",
      "enum": ["SE-N8N-CWF-440-Media-Package-Finalizer"]
    },
    "dossier_ref": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9-]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["CREATED", "VALIDATED", "FAILED"]
    },
    "payload": {
      "type": "object",
      "required": ["narrative", "context", "evidence", "quality", "status"],
      "properties": {
        "narrative": {
          "type": "object",
          "required": [
            "primary_content_title",
            "component_count",
            "component_types"
          ],
          "properties": {
            "primary_content_title": {
              "type": "string",
              "minLength": 5,
              "maxLength": 200
            },
            "component_count": {
              "type": "integer",
              "enum": [3],
              "description": "Always 3: thumbnail, visual, audio"
            },
            "component_types": {
              "type": "array",
              "enum": [
                ["thumbnail_concepts", "visual_specifications", "audio_brief"]
              ]
            }
          }
        },
        "context": {
          "type": "object",
          "required": [
            "sourced_from_thumbnail_packet_id",
            "sourced_from_visual_packet_id",
            "sourced_from_audio_packet_id",
            "sourced_from_context_engineering_packet_id",
            "dossier_id"
          ],
          "properties": {
            "sourced_from_thumbnail_packet_id": {
              "type": "string",
              "pattern": "^TCP-[0-9]+$"
            },
            "sourced_from_visual_packet_id": {
              "type": "string",
              "pattern": "^VASP-[0-9]+$"
            },
            "sourced_from_audio_packet_id": {
              "type": "string",
              "pattern": "^ABP-[0-9]+$"
            },
            "sourced_from_context_engineering_packet_id": {
              "type": "string",
              "pattern": "^CEP-[0-9]+$"
            },
            "dossier_id": {
              "type": "string",
              "pattern": "^[a-zA-Z0-9-]+$"
            }
          }
        },
        "evidence": {
          "type": "object",
          "required": [
            "thumbnail_specifications",
            "visual_specifications",
            "audio_specifications",
            "timing_alignment"
          ],
          "properties": {
            "thumbnail_specifications": {
              "type": "object",
              "required": ["concept_count", "strategies"],
              "properties": {
                "concept_count": {
                  "type": "integer",
                  "enum": [3]
                },
                "strategies": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": [
                      "curiosity_gap",
                      "authority_data",
                      "shock_urgency"
                    ]
                  },
                  "minItems": 3,
                  "maxItems": 3
                }
              }
            },
            "visual_specifications": {
              "type": "object",
              "required": [
                "total_visual_elements",
                "hook_elements",
                "body_elements",
                "closing_elements"
              ],
              "properties": {
                "total_visual_elements": {
                  "type": "integer",
                  "minimum": 5
                },
                "hook_elements": {
                  "type": "integer",
                  "minimum": 1
                },
                "body_elements": {
                  "type": "integer",
                  "minimum": 2
                },
                "closing_elements": {
                  "type": "integer",
                  "minimum": 1
                }
              }
            },
            "audio_specifications": {
              "type": "object",
              "required": [
                "total_word_count",
                "reading_pace_wpm",
                "annotated_script_sections"
              ],
              "properties": {
                "total_word_count": {
                  "type": "integer",
                  "minimum": 50
                },
                "reading_pace_wpm": {
                  "type": "integer",
                  "minimum": 140,
                  "maximum": 180
                },
                "annotated_script_sections": {
                  "type": "integer",
                  "enum": [3],
                  "description": "Hook, body, closing"
                }
              }
            },
            "timing_alignment": {
              "type": "array",
              "minItems": 3,
              "maxItems": 3,
              "items": {
                "type": "object",
                "required": [
                  "section",
                  "visual_duration_seconds",
                  "audio_duration_seconds",
                  "alignment_status",
                  "deviation_seconds"
                ],
                "properties": {
                  "section": {
                    "type": "string",
                    "enum": ["hook", "body", "closing"]
                  },
                  "visual_duration_seconds": {
                    "type": "number",
                    "minimum": 1
                  },
                  "audio_duration_seconds": {
                    "type": "number",
                    "minimum": 1
                  },
                  "alignment_status": {
                    "type": "string",
                    "enum": ["matched", "tight", "loose"]
                  },
                  "deviation_seconds": {
                    "type": "number",
                    "minimum": -5,
                    "maximum": 5
                  }
                }
              }
            }
          }
        },
        "quality": {
          "type": "object",
          "required": [
            "packet_completeness",
            "lineage_integrity",
            "timing_alignment_quality",
            "all_components_valid",
            "production_readiness_score"
          ],
          "properties": {
            "packet_completeness": {
              "type": "number",
              "enum": [1.0],
              "description": "Must be 1.0 (all components present)"
            },
            "lineage_integrity": {
              "type": "boolean",
              "enum": [true]
            },
            "timing_alignment_quality": {
              "type": "number",
              "minimum": 0.8,
              "maximum": 1.0
            },
            "all_components_valid": {
              "type": "boolean",
              "enum": [true]
            },
            "production_readiness_score": {
              "type": "number",
              "minimum": 0.8,
              "maximum": 1.0
            }
          }
        },
        "status": {
          "type": "object",
          "required": [
            "media_package_assembled",
            "all_components_present",
            "timing_aligned",
            "lineage_verified",
            "next_stage",
            "decision"
          ],
          "properties": {
            "media_package_assembled": {
              "type": "boolean",
              "enum": [true]
            },
            "all_components_present": {
              "type": "boolean",
              "enum": [true]
            },
            "timing_aligned": {
              "type": "boolean",
              "enum": [true]
            },
            "lineage_verified": {
              "type": "boolean",
              "enum": [true]
            },
            "next_stage": {
              "type": "string",
              "enum": ["WF-500"]
            },
            "decision": {
              "type": "string",
              "enum": ["PROCEED_TO_PUBLISHING_PIPELINE"]
            }
          }
        }
      }
    }
  }
}
