{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "M-320 Platform Packager packet schema",
  "type": "object",
  "description": "Output packet from CWF-320 (Platform Packager) - applies platform-specific formats and metadata",
  "required": [
    "instance_id",
    "artifact_family",
    "schema_version",
    "producer_workflow",
    "dossier_ref",
    "created_at",
    "status",
    "payload"
  ],
  "properties": {
    "instance_id": {"type": "string"},
    "artifact_family": {"type": "string", "const": "m320_packet"},
    "schema_version": {"type": "string"},
    "producer_workflow": {"type": "string"},
    "dossier_ref": {"type": "string"},
    "created_at": {"type": "string", "format": "date-time"},
    "status": {"type": "string", "enum": ["CREATED", "FINALIZED", "VALIDATED", "FAILED"]},
    "payload": {
      "type": "object",
      "properties": {
        "semantic_artifact_type": {"type": "string", "enum": ["platform_package_packet"]},
        "narrative": {
          "type": "object",
          "properties": {
            "platform_specs": {"type": "object"},
            "format_requirements": {"type": "object"},
            "metadata_template": {"type": "object"}
          }
        },
        "context": {"type": "object"},
        "evidence": {"type": "object"},
        "quality": {"type": "object"},
        "status": {"type": "object"}
      }
    }
  },
  "additionalProperties": true
}
